# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/.cov-tmp
# jsPDF가 테스트 중 루트에 떨구는 PDF 아티팩트
/*.pdf

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# kiro
.kiro

# mcp (contains access tokens)
.mcp.json

# Claude Code 로컬 설정/아티팩트 (프레임워크 자산은 커밋, 로컬만 제외)
.serena
.superpowers
.scratch/
.claude/settings.local.json
.claude/settings.local.*.json
.claude/.env.local*
.claude/local/
.claude/plans/
.claude/agent-memory/
.claude/worktrees/

# 스킬별 시크릿
.claude/skills/*/.env*
.claude/skills/*/secrets/
.claude/skills/*/*/*secret*
.claude/skills/*/*/*key*
.claude/skills/*/*/*token*
!.claude/skills/*/modules/*token*.md

# /html 등 임시 시각화 산출물
docs/_tmp/

### IDE ####
.idea

